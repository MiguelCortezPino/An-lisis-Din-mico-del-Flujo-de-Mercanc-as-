      "source": [
        "import pandas as pd\n",
        "import re\n",
        "\n",
        "# 1. Ruta del archivo en tu GitHub\n",
        "url = \"https://raw.githubusercontent.com/MiguelCortezPino/An-lisis-Din-mico-del-Flujo-de-Mercanc-as-/refs/heads/main/data/raw/Comercio_Internacional_de_Mercanc%C3%ADas_por_%C3%A1rea_geogr%C3%A1fica%20(1).csv\"\n",
        "\n",
        "# 2. Extracción Limpia: Saltamos las 3 primeras líneas de títulos institucionales\n",
        "df_raw = pd.read_csv(url, skiprows=3)\n",
        "\n",
        "# 3. Reconstrucción de Columnas (Combinando Año-Mes) para eliminar \"Unnamed\"\n",
        "years = df_raw.columns.tolist()\n",
        "months = df_raw.iloc[0].tolist()\n",
        "new_cols = []\n",
        "current_year = \"\"\n",
        "\n",
        "for y, m in zip(years, months):\n",
        "    m_clean = str(m).replace(\"(p)\", \"\").strip()\n",
        "    if 'Concepto' in str(y) or 'área' in str(y):\n",
        "        new_cols.append('Concepto')\n",
        "    else:\n",
        "        if 'Unnamed' not in str(y):\n",
        "            current_year = str(y).strip()\n",
        "        new_cols.append(f\"{current_year}-{m_clean}\")\n",
        "\n",
        "df_raw.columns = new_cols\n",
        "df_raw = df_raw.iloc[1:].reset_index(drop=True)\n",
        "df_raw['Concepto'] = df_raw['Concepto'].astype(str).str.strip()\n",
        "\n",
        "# =========================================================\n",
        "# PROCESO DE EXTRACCIÓN Y LIMPIEZA GEOGRÁFICA\n",
        "# =========================================================\n",
        "\n",
        "# Creamos columnas vacías para almacenar la estructura jerárquica\n",
        "df_raw['Zona'] = None\n",
        "df_raw['Departamento'] = None\n",
        "df_raw['Tipo_Movimiento'] = None\n",
        "\n",
        "current_movimiento = \"\"\n",
        "current_zona = \"\"\n",
        "current_depto = \"\"\n",
        "\n",
        "rows_curated = []\n",
        "rows_rejected = []\n",
        "\n",
        "# Recorremos el archivo fila por fila para entender la estructura de árbol del BCR\n",
        "for index, row in df_raw.iterrows():\n",
        "    concepto = row['Concepto']\n",
        "\n",
        "    # Detectar si es la sección principal de Exportaciones o Importaciones\n",
        "    if \"Exportaciones (FOB)\" in concepto:\n",
        "        current_movimiento = \"Exportaciones (FOB)\"\n",
        "        current_zona = \"Todo el País\"\n",
        "        current_depto = \"Todo el País\"\n",
        "        continue\n",
        "    elif \"Importaciones (CIF)\" in concepto:\n",
        "        current_movimiento = \"Importaciones (CIF)\"\n",
        "        current_zona = \"Todo el País\"\n",
        "        current_depto = \"Todo el País\"\n",
        "        continue\n",
        "\n",
        "    # Validar la numeración jerárquica con expresiones regulares\n",
        "    # Ejemplo: \"1.1 Zona Occidental\" -> Zona\n",
        "    match_zona = re.match(r'^1\\.\\d+\\s+(.+)', concepto)\n",
        "    # Ejemplo: \"1.1.1 Ahuachapán\" -> Departamento\n",
        "    match_depto = re.match(r'^1\\.\\d+\\.\\d+\\s+(.+)', concepto)\n",
        "    # Ejemplo: \"1.1.1.1 Ahuachapán Centro\" -> Municipio (Va a Rejects)\n",
        "    match_municipio = re.match(r'^1\\.\\d+\\.\\d+\\.\\d+\\s+(.+)', concepto)\n",
        "\n",
        "    if match_municipio:\n",
        "        # Enviamos los municipios a rejects para no duplicar datos a nivel departamental\n",
        "        rows_rejected.append(row)\n",
        "    elif match_depto:\n",
        "        current_depto = match_depto.group(1).strip()\n",
        "        # Guardamos el registro asignándole su movimiento y zona correspondiente\n",
        "        row_copy = row.copy()\n",
        "        row_copy['Tipo_Movimiento'] = current_movimiento\n",
        "        row_copy['Zona'] = current_zona\n",
        "        row_copy['Departamento'] = current_depto\n",
        "        rows_curated.append(row_copy)\n",
        "    elif match_zona:\n",
        "        current_zona = match_zona.group(1).strip()\n",
        "        current_depto = \"General\"\n",
        "    else:\n",
        "        # Notas al pie de página o celdas vacías van a rejects\n",
        "        rows_rejected.append(row)\n",
        "\n",
        "# Convertimos las listas de filas procesadas de vuelta a DataFrames\n",
        "df_geo_curated = pd.DataFrame(rows_curated)\n",
        "df_geo_rejected = pd.DataFrame(rows_rejected)\n",
        "\n",
        "# =========================================================\n",
        "# UNPIVOTING VERTICAL CON ENFOQUE GEOGRÁFICO\n",
        "# =========================================================\n",
        "\n",
        "# Columnas que representan los meses\n",
        "columnas_meses = [col for col in df_geo_curated.columns if col not in ['Concepto', 'Zona', 'Departamento', 'Tipo_Movimiento']]\n",
        "\n",
        "df_vertical = df_geo_curated.melt(\n",
        "    id_vars=['Tipo_Movimiento', 'Zona', 'Departamento'],\n",
        "    value_vars=columnas_meses,\n",
        "    var_name='Fecha',\n",
        "    value_name='Monto_Miles_USD'\n",
        ")\n",
        "\n",
        "# Convertimos los montos a valores numéricos decimales\n",
        "df_vertical[\"Monto_Miles_USD\"] = pd.to_numeric(df_vertical[\"Monto_Miles_USD\"], errors='coerce')\n",
        "\n",
        "# Ordenamiento Cronológico y Geográfico\n",
        "month_order = {'Mar':3, 'Abr':4, 'May':5, 'Jun':6, 'Jul':7, 'Ago':8, 'Sep':9, 'Oct':10, 'Nov':11, 'Dic':12, 'Ene':1, 'Feb':2}\n",
        "def mapear_orden(row):\n",
        "    try:\n",
        "        anio, mes = row['Fecha'].split('-')\n",
        "        return (int(anio), month_order.get(mes, 0))\n",
        "    except:\n",
        "        return (0, 0)\n",
        "\n",
        "df_vertical['_orden'] = df_vertical.apply(mapear_orden, axis=1)\n",
        "df_final_curated = df_vertical.sort_values(by=[\"_orden\", \"Zona\", \"Departamento\", \"Tipo_Movimiento\"]).drop(columns=[\"_orden\"]).reset_index(drop=True)\n",
        "\n",
        "# Reorganizar el orden de las columnas para una visualización perfecta\n",
        "df_final_curated = df_final_curated[['Tipo_Movimiento', 'Zona', 'Departamento', 'Fecha', 'Monto_Miles_USD']]\n",
        "\n",
        "# 8. Guardar los archivos curados y rechazados geográficamente\n",
        "df_final_curated.to_csv(\"E_comercio_curated.csv\", index=False)\n",
        "df_geo_rejected.to_csv(\"E_comercio_rejects.csv\", index=False)\n",
        "\n",
        "print(\"==================================================================\")\n",
        "print(\" ¡PROCESO DE CURACIÓN GEOGRÁFICA COMPLETADO CON ÉXITO! \")\n",
        "print(\"==================================================================\")\n",
        "print(f\"-> Archivo CURADO guardado como 'E_comercio_curated.csv'  | Filas tabulares: {len(df_final_curated)}\")\n",
        "print(f\"-> Archivo RECHAZADOS guardado como 'E_comercio_rejects.csv' | Filas originales omitidas: {len(df_geo_rejected)}\")\n",
        "print(\"\\nMuestra del nuevo formato enriquecido con Departamentos:\")\n",
        "df_final_curated.head(10)"
      ],
